# Copy this to .env and fill in your local values
# cp .env.example .env

# ── App ───────────────────────────────────────────────────────
APP_TITLE=AI Medical Platform
APP_VERSION=0.1.0
DEBUG=false

# ── Module toggles (set false to disable a module at runtime) ─
ENABLE_XRAY=true
ENABLE_REPORT=true
ENABLE_DRUG=true
ENABLE_TUMOR=true

# ── Model weight paths (local — never commit actual .pth files) ─
XRAY_MODEL_PATH=data/models/resnet18_xray.pth
TUMOR_MODEL_PATH=data/models/unet_tumor.pth
REPORT_MODEL_NAME=allenai/scibert_scivocab_uncased

# ── Performance ──────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10.0
INFERENCE_TIMEOUT_SECONDS=30.0
